{
  "manifest_version": 3,
  "name": "30 Minute DOM History",
  "description": "Tracks visited pages and stores a rolling 30-minute local history with page DOM snapshots.",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "DOM History",
    "default_popup": "popup.html"
  }
}